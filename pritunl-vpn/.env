# ============================================================
# DOCKER COMPOSE — Serveur VPN Pritunl + MongoDB
# Auteur : Mbassi Elessa | KEYCE M1 IABD
# TP3    : Conduite de Projet — AGILE/DEVOPS/KANBAN
# ============================================================
# Prérequis : vérifier le module tun
#   lsmod | grep tun
#   Si absent : sudo modprobe tun
#
# Lancement : docker-compose up -d
# Arrêt     : docker-compose down
# ============================================================

version: '3.8'

services:

  # ──────────────────────────────────────────
  # SERVICE 1 : MongoDB
  # Base de données de Pritunl
  # ──────────────────────────────────────────
  mongodb:
    image: mongo:5.0
    container_name: pritunl-mongodb
    restart: unless-stopped

    environment:
      MONGO_INITDB_ROOT_USERNAME: ${MONGO_ROOT_USER}
      MONGO_INITDB_ROOT_PASSWORD: ${MONGO_ROOT_PASSWORD}
      MONGO_INITDB_DATABASE: pritunl

    volumes:
      - ./volumes/mongodb:/data/db

    networks:
      - pritunl-net

    expose:
      - "27017"

    healthcheck:
      test: ["CMD", "mongosh", "--eval", "db.adminCommand('ping')"]
      interval: 10s
      timeout: 5s
      retries: 5

  # ──────────────────────────────────────────
  # SERVICE 2 : Pritunl
  # Serveur VPN
  # ──────────────────────────────────────────
  pritunl:
    image: jippi/pritunl:latest
    container_name: pritunl-server
    restart: unless-stopped
    privileged: true

    depends_on:
      mongodb:
        condition: service_healthy

    environment:
      PRITUNL_MONGODB_URI: mongodb://${MONGO_ROOT_USER}:${MONGO_ROOT_PASSWORD}@mongodb:27017/pritunl?authSource=admin

    volumes:
      - ./volumes/pritunl:/var/lib/pritunl

    ports:
      - "443:443"
      - "80:80"
      - "1194:1194/udp"

    networks:
      - pritunl-net

    devices:
      - /dev/net/tun:/dev/net/tun

    cap_add:
      - NET_ADMIN

# ──────────────────────────────────────────
# RÉSEAU INTERNE
# ──────────────────────────────────────────
networks:
  pritunl-net:
    driver: bridge
